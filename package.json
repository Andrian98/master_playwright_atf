{
  "name": "parabank-playwright-atf",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "cross-env NODE_OPTIONS='--no-deprecation' playwright test",
    "test:chromium": "cross-env BROWSER_PROJECT=chromium NODE_OPTIONS='--no-deprecation' playwright test",
    "test:firefox": "cross-env BROWSER_PROJECT=firefox NODE_OPTIONS='--no-deprecation' playwright test",
    "test:webkit": "cross-env BROWSER_PROJECT=webkit NODE_OPTIONS='--no-deprecation' playwright test",
    "test:browsers": "cross-env BROWSER_PROJECT=all NODE_OPTIONS='--no-deprecation' playwright test",
    "test:ui": "cross-env NODE_OPTIONS='--no-deprecation' playwright test tests/ui",
    "test:ui:headless": "cross-env HEADLESS=true NODE_OPTIONS='--no-deprecation' playwright test tests/ui",
    "test:ui:headed": "cross-env HEADLESS=false NODE_OPTIONS='--no-deprecation' playwright test tests/ui",
    "test:ui:evidence": "cross-env CAPTURE_CHECKPOINT_SCREENSHOTS=true NODE_OPTIONS='--no-deprecation' playwright test tests/ui",
    "test:api": "cross-env NODE_OPTIONS='--no-deprecation' playwright test tests/api",
    "test:ci": "cross-env CI=true NODE_OPTIONS='--no-deprecation' playwright test tests --workers=2 --retries=1",
    "clean": "node -e \"const fs=require('fs'); ['evidence','playwright-report','test-results','snapshots'].forEach(d => fs.rmSync(d,{recursive:true,force:true}))\"",
    "report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1"
  },
  "dependencies": {
    "winston": "^3.19.0"
  }
}
